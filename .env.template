# NICU-GPT Configuration File
# Copy this to .env and fill in your values

# ============================================================================
# API KEYS (for evaluation)
# ============================================================================

# OpenAI API key for GPT-4 evaluation
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Alternative: Anthropic API key for Claude evaluation
# ANTHROPIC_API_KEY=


# ============================================================================
# WANDB (for experiment tracking)
# ============================================================================

# Weights & Biases API key (optional)
# Get from: https://wandb.ai/authorize
WANDB_API_KEY=

# Project name for wandb
WANDB_PROJECT=nicu-gpt

# Run name prefix
WANDB_RUN_PREFIX=llama3-qlora


# ============================================================================
# MODEL CONFIGURATION
# ============================================================================

# Base model to use
BASE_MODEL=unsloth/llama-3-8b-Instruct-bnb-4bit

# Maximum sequence length
MAX_SEQ_LENGTH=2048

# LoRA rank (higher = more parameters, better quality, more memory)
LORA_R=16

# Learning rate
LEARNING_RATE=2e-4

# Number of training epochs
NUM_EPOCHS=3

# Batch size (reduce if OOM)
BATCH_SIZE=2

# Gradient accumulation steps
GRADIENT_ACCUMULATION_STEPS=4


# ============================================================================
# DATA CONFIGURATION
# ============================================================================

# Path to training data
TRAINING_DATA_PATH=data/processed/nicu_training_data.json

# Path to evaluation golden set
EVAL_DATA_PATH=data/evaluation/golden_set.json


# ============================================================================
# OUTPUT CONFIGURATION
# ============================================================================

# Output directory for models
OUTPUT_DIR=output/nicu-llama-qlora

# Results directory
RESULTS_DIR=results


# ============================================================================
# ADVANCED OPTIONS
# ============================================================================

# Enable gradient checkpointing (saves memory)
USE_GRADIENT_CHECKPOINTING=true

# Use 8-bit optimizer (saves memory)
USE_8BIT_OPTIMIZER=true

# Save model every N steps
SAVE_STEPS=50

# Evaluation strategy (steps, epoch, no)
EVALUATION_STRATEGY=steps

# Random seed for reproducibility
RANDOM_SEED=3407
